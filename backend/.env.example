# ── Entorno ─────────────────────────────────────────────────────────────────
FLASK_ENV=development          # "production" en Render

# ── Seguridad ────────────────────────────────────────────────────────────────
SECRET_KEY=cambiar_esto_en_produccion
JWT_SECRET_KEY=cambiar_esto_en_produccion

# ── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///hublecop_dev.db
# Producción (Supabase → Session Pooler, Transaction mode no soporta migraciones):
# DATABASE_URL=postgresql://user:password@db.xxxx.supabase.co:5432/postgres

# ── Organizador ──────────────────────────────────────────────────────────────
ADMIN_USERNAME=organizador
ADMIN_PASSWORD=cambiar_esto

# ── CORS (solo producción) ───────────────────────────────────────────────────
# ALLOWED_ORIGINS=https://tu-app.vercel.app
